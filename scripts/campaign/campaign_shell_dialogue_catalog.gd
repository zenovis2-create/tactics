static func get_worldview_fragment_cards(collected_fragment_ids: Array[String], world_timeline_id: String = "A") -> Array[Dictionary]:
	var normalized_timeline_id := _normalize_world_timeline_id(world_timeline_id)
	var cards: Array[Dictionary] = []
	for fragment_entry in WORLDVIEW_FRAGMENT_LIBRARY:
		var entry := fragment_entry.duplicate(true)
		var fragment_id := String(entry.get("id", "")).strip_edges()
		var collected := collected_fragment_ids.has(fragment_id)
		cards.append({
			"id": fragment_id,
			"name": String(entry.get("name", fragment_id)),
			"speaker": String(entry.get("speaker", "Witness")),
			"description": String(entry.get("description", "")).strip_edges() if collected else "아직 회수되지 않은 세계관 조각입니다.",
			"dialogue": String(entry.get("dialogue_timeline_b", "")).strip_edges() if normalized_timeline_id == "B" else String(entry.get("dialogue_timeline_a", "")).strip_edges(),
			"collected": collected
		})
	return cards

static func get_choice_dialogue(choice_point_id: StringName, world_timeline_id: String = "A", worldview_complete: bool = false) -> Dictionary:
	var choice_data: Dictionary = {}
	match choice_point_id:
		&"ch05_camp":
			choice_data = CH05_CAMP_CHOICE.duplicate(true)
		&"ch07_interlude":
			choice_data = CH07_INTERLUDE_CHOICE.duplicate(true)
		&"ch08_pre_boss":
			choice_data = CH08_PRE_BOSS_CHOICE.duplicate(true)
		&"ch09a_camp":
			choice_data = CH09A_CAMP_CHOICE.duplicate(true)
		&"ch10_pre_finale":
			choice_data = CH10_PRE_FINALE_CHOICE.duplicate(true)
		_:
			choice_data = {}
	if choice_data.is_empty() or not worldview_complete:
		return choice_data
	choice_data["dialogue_entries"] = _apply_worldview_truth_annotation(_duplicate_string_array(choice_data.get("dialogue_entries", [])), world_timeline_id, worldview_complete)
	return choice_data

static func _get_dialogue_speaker_name(speaker_id: String) -> String:
	match speaker_id.strip_edges().to_lower():
		"leonika", "enemy_saria":
			return "Leonika"
		"serin":
			return "Serin"
		"bran":
			return "Bran"
		"tia":
			return "Tia"
		"enoch":
			return "Enoch"
		"karl":
			return "Karl"
		"noah":
			return "Noah"
		"mira":
			return "Mira"
		"lete":
			return "Lete"
		"melkion":
			return "Melkion"
		_:
			return speaker_id.strip_edges().capitalize()
