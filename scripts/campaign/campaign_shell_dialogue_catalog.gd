static func _normalize_world_timeline_id(world_timeline_id: String) -> String:
	var normalized := world_timeline_id.strip_edges().to_upper()
	return "B" if normalized == "B" else "A"

static func _duplicate_string_array(value: Variant) -> Array[String]:
	var lines: Array[String] = []
	if typeof(value) != TYPE_ARRAY and typeof(value) != TYPE_PACKED_STRING_ARRAY:
		return lines
	for entry in value:
		lines.append(String(entry))
	return lines

static func _append_unique_lines(base_lines: Array[String], added_lines: Array[String]) -> Array[String]:
	var lines := base_lines.duplicate()
	for line in added_lines:
		if not lines.has(line):
			lines.append(line)
	return lines

static func _apply_worldview_truth_annotation(lines: Array[String], world_timeline_id: String, worldview_complete: bool) -> Array[String]:
	if not worldview_complete:
		return lines.duplicate()
	return _append_unique_lines(lines, get_special_dialogue(&"truth_annotation", world_timeline_id))

