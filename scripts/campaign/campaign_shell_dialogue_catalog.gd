static func get_intro_dialogue(chapter_id: StringName) -> Array[String]:
	match chapter_id:
		&"CH02":
			return CH02_INTRO_DIALOGUE.duplicate()
		&"CH03":
			return CH03_INTRO_DIALOGUE.duplicate()
		&"CH04":
			return CH04_INTRO_DIALOGUE.duplicate()
		&"CH05":
			return CH05_INTRO_DIALOGUE.duplicate()
		&"CH06":
			return CH06_INTRO_DIALOGUE.duplicate()
		&"CH07":
			return CH07_INTRO_DIALOGUE.duplicate()
		&"CH08":
			return CH08_INTRO_DIALOGUE.duplicate()
		&"CH09A":
			return CH09A_INTRO_DIALOGUE.duplicate()
		&"CH09B":
			return CH09B_INTRO_DIALOGUE.duplicate()
		&"CH10":
			return CH10_INTRO_DIALOGUE.duplicate()
		_:
			return []

static func get_interlude_dialogue(chapter_id: StringName) -> Array[String]:
	match chapter_id:
		&"CH01":
			return CH01_INTERLUDE_DIALOGUE.duplicate()
		&"CH02":
			return CH02_INTERLUDE_DIALOGUE.duplicate()
		&"CH03":
			return CH03_INTERLUDE_DIALOGUE.duplicate()
		&"CH04":
			return CH04_INTERLUDE_DIALOGUE.duplicate()
		&"CH05":
			return CH05_INTERLUDE_DIALOGUE.duplicate()
		&"CH06":
			return CH06_INTERLUDE_DIALOGUE.duplicate()
		&"CH07":
			return CH07_INTERLUDE_DIALOGUE.duplicate()
		&"CH08":
			return CH08_INTERLUDE_DIALOGUE.duplicate()
		&"CH09A":
			return CH09A_INTERLUDE_DIALOGUE.duplicate()
		&"CH09B":
			return CH09B_INTERLUDE_DIALOGUE.duplicate()
		_:
			return []

static func get_resolution_dialogue() -> Array[String]:
	return CH10_RESOLUTION_DIALOGUE.duplicate()

static func get_hidden_recruit_dialogue(recruit_id: StringName) -> Array[String]:
	match recruit_id:
		&"lete":
			return LETE_RECRUIT_DIALOGUE.duplicate()
		&"mira":
			return MIRA_RECRUIT_DIALOGUE.duplicate()
		&"melkion":
			return MELKION_RECRUIT_DIALOGUE.duplicate()
		_:
			return []

static func get_choice_dialogue(choice_point_id: StringName) -> Dictionary:
	match choice_point_id:
		&"ch05_camp":
			return CH05_CAMP_CHOICE.duplicate(true)
		&"ch07_interlude":
			return CH07_INTERLUDE_CHOICE.duplicate(true)
		&"ch08_pre_boss":
			return CH08_PRE_BOSS_CHOICE.duplicate(true)
		&"ch09a_camp":
			return CH09A_CAMP_CHOICE.duplicate(true)
		&"ch10_pre_finale":
			return CH10_PRE_FINALE_CHOICE.duplicate(true)
		_:
			return {}
