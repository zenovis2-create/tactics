[ext_resource type="Script" path="res://scripts/data/accessory_data.gd" id="1_accessory"]

[resource]
script = ExtResource("1_accessory")
accessory_id = &"acc_gatekeeper_ring"
display_name = "Gatekeeper Ring"
summary = "Object-play accessory. Speeds movement after switches, levers, and gate work."
