Vector2i(2, 4): 1,
Vector2i(5, 5): 1
}
terrain_features = [{
"type": "destructible",
"position": Vector2i(2, 4),
"radius": 0,
"effect": "The west root seal can be broken to start opening the archive gate."
}, {
"type": "narrow_pass",
"position": Vector2i(4, 4),
"radius": 1,
"effect": "The root gate squeezes the squad through a single indexed breach."
}, {
"type": "high_ground",
"position": Vector2i(5, 5),
"radius": 0,
"effect": "The east root index overlooks the first archive-core route."
}]
optional_objectives = [{
"id": "ch09b_01_west_root_seal",
"description": "서쪽 근원 봉인을 부숴 기록보관소 관문을 열 첫 틈을 만든다.",
"condition": "flag:ch09b_01_west_root_seal",
"star_value": 1
}, {
"id": "ch09b_01_east_root_index",
"description": "동쪽 근원 색인을 확보해 첫 내부 서가로 향하는 경로를 고정한다.",
"condition": "flag:ch09b_01_east_root_index",
"star_value": 1
}]
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
objective_text = "Break the west root seal and secure the east root index to open the archive gate."
stage_objective_hint = "서쪽 봉인을 부수고 동쪽 색인을 확보해 중앙 기록보관소 문을 연다."
interaction_objective_texts = PackedStringArray("서쪽 근원 봉인을 부수고 동쪽 근원 색인을 확보해 기록보관소 문을 연다. (0/2)", "근원 관문 제어 지점 하나를 확보했다. 남은 기록 잠금을 해제한다. (1/2)", "근원 관문이 열렸다. 첫 기록 핵심 경로가 확보되었다. (2/2)")
interaction_objective_state_ids = [&"root_gate_locked", &"root_gate_partial", &"root_gate_open"]
landmark_labels = PackedStringArray("서쪽 근원 봉인", "기록보관소 관문", "동쪽 근원 색인")
choice_point_id = &"ch09a_kyle_testimony"
start_cutscene_id = &"ch09b_01_intro"
clear_cutscene_id = &"ch09b_01_outro"
next_destination_summary = "다음: 기록보관소 문을 지나 지워진 이름들의 서가로 들어간다."
post_battle_bark_rules = [{
"id": "ch09b_01_root_gate_report_ready",
"speaker": "Guide",
"text": "근원의 문이 열렸다. 이제 전장은 병영이 아니라 기록이 사람을 거르는 곳이다.",
"section": "story",
"conditions": {"outcome": "victory", "post_battle_handoff": true}
}, {
"id": "ch09b_01_root_seal_ack",
"speaker": "Kyle",
"text": "서쪽 봉인을 부쉈지만 내 계급은 여기서 아무 힘도 없군. 증언만 들고 들어가야 한다.",
"section": "bonds",
"conditions": {"outcome": "victory", "optional_completed": ["ch09b_01_west_root_seal"]}
}, {
"id": "ch09b_01_root_index_ack",
"speaker": "Guide",
"text": "동쪽 근원 색인을 확보했다. 기록보관소 안쪽 서가로 가는 첫 경로가 고정됐다.",
"section": "story",
"conditions": {"outcome": "victory", "optional_completed": ["ch09b_01_east_root_index"]}
}, {
"id": "ch09b_01_full_root_gate_read",
"speaker": "System",
"text": "근원 봉인 파괴와 근원 색인 확보 결과가 기록보관소 관문 판정에 반영됐다.",
"section": "telemetry",
"conditions": {"outcome": "victory", "optional_completed": ["ch09b_01_west_root_seal", "ch09b_01_east_root_index"]}
}]
