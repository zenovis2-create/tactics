[gd_resource type="Resource" script_class="StageData" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/data/stage_data.gd" id="1_stage"]
[ext_resource type="Resource" path="res://data/units/ally_vanguard.tres" id="2_ally_a"]
[ext_resource type="Resource" path="res://data/units/ally_scout.tres" id="3_ally_b"]
[ext_resource type="Resource" path="res://data/units/enemy_raider.tres" id="4_enemy_a"]
[ext_resource type="Resource" path="res://data/units/enemy_skirmisher.tres" id="5_enemy_b"]
[ext_resource type="Resource" path="res://data/objects/ch09b_01_west_root_seal.tres" id="6_object_a"]
[ext_resource type="Resource" path="res://data/objects/ch09b_01_east_root_index.tres" id="7_object_b"]

[resource]
script = ExtResource("1_stage")
stage_id = &"CH09B_01"
stage_title = "Root Gate"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 3), Vector2i(4, 3), Vector2i(4, 4)]
terrain_move_costs = {
Vector2i(2, 4): 2,
Vector2i(5, 5): 2
}
terrain_types = {
Vector2i(2, 4): &"seal",
Vector2i(5, 5): &"seal"
}
terrain_defense_bonuses = {
Vector2i(2, 4): 1,
Vector2i(5, 5): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
objective_text = "Break the west root seal and secure the east root index to open the archive gate."
stage_objective_hint = "서쪽 봉인을 부수고 동쪽 색인을 확보해 중앙 기록보관소 문을 연다."
interaction_objective_texts = PackedStringArray("서쪽 근원 봉인을 부수고 동쪽 근원 색인을 확보해 기록보관소 문을 연다. (0/2)", "근원 관문 제어 지점 하나를 확보했다. 남은 기록 잠금을 해제한다. (1/2)", "근원 관문이 열렸다. 첫 기록 핵심 경로가 확보되었다. (2/2)")
interaction_objective_state_ids = [&"root_gate_locked", &"root_gate_partial", &"root_gate_open"]
landmark_labels = PackedStringArray("서쪽 근원 봉인", "기록보관소 관문", "동쪽 근원 색인")
start_cutscene_id = &"ch09b_01_intro"
clear_cutscene_id = &"ch09b_01_outro"
next_destination_summary = "다음: 기록보관소 문을 지나 지워진 이름들의 서가로 들어간다."
