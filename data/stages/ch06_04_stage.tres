[resource]
script = ExtResource("1_stage")
stage_id = &"CH06_04"
stage_title = "Oath Hall"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 2), Vector2i(3, 3), Vector2i(4, 2)]
terrain_move_costs = {
Vector2i(2, 5): 2,
Vector2i(5, 2): 2
}
terrain_types = {
Vector2i(2, 5): &"archives",
Vector2i(5, 2): &"keep"
}
terrain_defense_bonuses = {
Vector2i(2, 5): 1,
Vector2i(5, 2): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b"), ExtResource("8_object_c")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Seize both oath archives and break the ceremonial seal to expose Valgar's ramp. (0/3)", "One oath-hall record point is secured. Seize the remaining archive controls. (1/3)", "Two oath-hall record points are secured. Break the ceremonial seal. (2/3)", "Oath-hall records seized. The ceremonial seal is broken. (3/3)")
interaction_objective_state_ids = [&"oath_hall_records_locked", &"oath_hall_records_partial", &"oath_hall_records_aligned", &"oath_hall_records_exposed"]
start_cutscene_id = &"ch06_04_intro"
clear_cutscene_id = &"ch06_04_outro"
next_destination_summary = "The oath hall seals break, and the inner ramp to Valgar's keep is exposed."
