loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Secure the central lift, then hold it through the next round. (0/1)", "The central lift is secured. Hold until the next round begins. (1/2)", "The central lift held through the counterpush. Varten's inner censor line is exposed. (2/2)")
interaction_objective_state_ids = [&"central_lift_unsecured", &"central_lift_holding", &"central_lift_secured"]
rescue_objective_id = &"central_lift_access"
rescue_objective_required_count = 1
rescue_objective_object_ids = [&"ch09a_04_central_officer_release_point"]
hold_objective_id = &"central_lift_hold"
hold_objective_required_turns = 1
start_cutscene_id = &"ch09a_04_intro"
clear_cutscene_id = &"ch09a_04_outro"
next_destination_summary = "Securing the central lift opens Varten's final censor line at the central citadel approach."
