interaction_objective_texts = PackedStringArray("맹세 두루마리를 회수하고 검열 표식을 조사해 버려진 장교 경로를 드러낸다. (0/2)", "맹세 전당 단서 하나를 확보했다. 남은 장교 흔적을 찾는다. (1/2)", "맹세 전당 단서 두 개를 모두 확보했다. 버려진 장교 경로가 확정되었다. (2/2)")
interaction_objective_state_ids = [&"oath_hall_unread", &"oath_hall_partial", &"oath_hall_confirmed"]
landmark_labels = PackedStringArray("맹세 두루마리", "맹세 전당 바닥", "검열 표식")
