[resource]
script = ExtResource("1_stage")
stage_id = &"CH06_02"
stage_title = "Battery Line"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(2, 3), Vector2i(3, 3), Vector2i(5, 4)]
terrain_move_costs = {
Vector2i(1, 2): 2,
Vector2i(6, 4): 2
}
terrain_types = {
Vector2i(1, 2): &"battery",
Vector2i(6, 4): &"battery"
}
terrain_defense_bonuses = {
Vector2i(1, 2): 1,
Vector2i(6, 4): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b"), ExtResource("8_object_c")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Cut the Valtor battery line by collapsing both flank winches and releasing the center chain-lift gate. (0/3)", "One line-control point is secured. Collapse the remaining battery controls. (1/3)", "Two line-control points are secured. Release the final chain-lift gate control. (2/3)", "Battery line broken. The chain-lift gate is open. (3/3)")
interaction_objective_state_ids = [&"valtor_line_control_locked", &"valtor_line_control_partial", &"valtor_line_control_pressured", &"valtor_line_control_open"]
start_cutscene_id = &"ch06_02_intro"
clear_cutscene_id = &"ch06_02_outro"
next_destination_summary = "The broken batteries reveal the prison roads descending beneath Valtor."
