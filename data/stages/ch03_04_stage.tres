"type": "sacred_ground",
"position": Vector2i(2, 5),
"radius": 1,
"effect": "The west resin shrine stabilizes wildfire echoes around the lower path."
}, {
"type": "narrow_pass",
"position": Vector2i(3, 3),
"radius": 1,
"effect": "Resin roots pinch the center approach into a controlled lane."
}, {
"type": "destructible",
"position": Vector2i(5, 2),
