enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 2), Vector2i(3, 3), Vector2i(4, 3)]
terrain_move_costs = {
Vector2i(2, 5): 2,
Vector2i(5, 2): 2
}
