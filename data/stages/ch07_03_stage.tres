"description": "목격 표식을 확인해 네리의 재등장 위치를 좁힌다.",
"condition": "flag:ch07_03_witness_mark",
"star_value": 1
}]
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
stage_objective_hint = "행렬 두루마리를 회수하고 성당 진입 경로를 추적한다."
interaction_objective_texts = PackedStringArray("행렬 두루마리와 목격 표식을 회수해 성당 경로를 추적한다. (0/2)", "행렬 단서 하나를 확보했다. 남은 목격 지점을 찾는다. (1/2)", "행렬 단서 두 개를 모두 확보했다. 성당 경로가 확정되었다. (2/2)")
interaction_objective_state_ids = [&"procession_route_unread", &"procession_route_partial", &"procession_route_confirmed"]
landmark_labels = PackedStringArray("행렬 두루마리", "사당 대로", "목격 표식")
start_cutscene_id = &"ch07_03_intro"
clear_cutscene_id = &"ch07_03_outro"
next_destination_summary = "다음: 사당 대로를 따라 성당 앞마당으로 올라간다."
post_battle_bark_rules = [{
"id": "ch07_03_procession_report_ready",
"speaker": "Guide",
"text": "이름 없는 행렬의 길을 끊었다. 성당 앞마당으로 가는 단서는 아직 사라지지 않았다.",
"section": "story",
"conditions": {"outcome": "victory", "post_battle_handoff": true}
}, {
"id": "ch07_03_procession_roll_ack",
"speaker": "Tia",
"text": "두루마리에 남은 이름들이 너무 적어. 그래서 더더욱 지금 붙잡아야 해.",
"section": "bonds",
"conditions": {"outcome": "victory", "optional_completed": ["ch07_03_procession_roll"]}
}, {
"id": "ch07_03_witness_mark_ack",
"speaker": "Serin",
"text": "목격 표식이 네리의 길을 좁혀 줬어. 아직 늦었다고 말하긴 싫어.",
"section": "story",
"conditions": {"outcome": "victory", "optional_completed": ["ch07_03_witness_mark"]}
}, {
"id": "ch07_03_full_procession_read",
"speaker": "System",
"text": "행렬 두루마리 회수와 목격 표식 확인 결과가 이름 없는 행렬 판정에 반영됐다.",
"section": "telemetry",
"conditions": {"outcome": "victory", "optional_completed": ["ch07_03_procession_roll", "ch07_03_witness_mark"]}
}]
