loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Recover the procession roll and witness mark to trace the cathedral route. (0/2)", "One procession clue is secured. Find the remaining witness point. (1/2)", "Both procession clues are secured. The cathedral route is confirmed. (2/2)")
