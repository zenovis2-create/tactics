[resource]
script = ExtResource("1_stage")
stage_id = &"CH08_01"
stage_title = "Vanished Trail"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 3), Vector2i(4, 3), Vector2i(4, 4)]
terrain_move_costs = {
Vector2i(2, 4): 2,
Vector2i(5, 5): 2
}
terrain_types = {
Vector2i(2, 4): &"night_forest",
Vector2i(5, 5): &"night_forest"
}
terrain_defense_bonuses = {
Vector2i(2, 4): 1,
Vector2i(5, 5): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Trace the hound sign and cut the signal post to collapse the vanished trail forks. (0/2)", "One route-pressure point is resolved. Collapse the remaining fork. (1/2)", "Both route-pressure points are resolved. The vanished trail is narrowed to one lane. (2/2)")
interaction_objective_state_ids = [&"hound_route_split", &"hound_route_partial", &"hound_route_narrowed"]
start_cutscene_id = &"ch08_01_intro"
clear_cutscene_id = &"ch08_01_outro"
next_destination_summary = "The black-hound trail forks collapse into a single lane leading toward the ambush woods."
