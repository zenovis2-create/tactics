[resource]
script = ExtResource("1_stage")
stage_id = &"CH10_01"
stage_title = "Eclipse Eve"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 3), Vector2i(4, 3), Vector2i(4, 4)]
terrain_move_costs = {
Vector2i(2, 4): 2,
Vector2i(5, 5): 2
}
terrain_types = {
Vector2i(2, 4): &"eclipse",
Vector2i(5, 5): &"eclipse"
}
terrain_defense_bonuses = {
Vector2i(2, 4): 1,
Vector2i(5, 5): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
stage_objective_hint = "식경 서판을 읽고 승강기를 해제해 첫 탑 진입을 시작한다."
interaction_objective_texts = PackedStringArray("식경 서판을 읽고 승강기 걸쇠를 풀어 첫 상승 경로를 연다. (0/2)", "상승 제어 지점 하나를 확보했다. 남은 탑 걸쇠를 해제한다. (1/2)", "상승 제어 지점 두 곳을 모두 확보했다. 첫 탑 경로가 열렸다. (2/2)")
interaction_objective_state_ids = [&"tower_ascent_locked", &"tower_ascent_partial", &"tower_ascent_open"]
landmark_labels = PackedStringArray("식경 서판", "외곽 승강기", "첫 공명탑")
start_cutscene_id = &"ch10_01_intro"
clear_cutscene_id = &"ch10_01_outro"
next_destination_summary = "다음: 외곽 승강기를 타고 첫 공명탑으로 향한다."
