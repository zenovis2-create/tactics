enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 3), Vector2i(4, 3), Vector2i(4, 4)]
terrain_move_costs = {
Vector2i(2, 4): 2,
Vector2i(5, 5): 2
}
terrain_types = {
Vector2i(2, 4): &"eclipse",
Vector2i(5, 5): &"eclipse"
}
terrain_defense_bonuses = {
Vector2i(2, 4): 1,
Vector2i(5, 5): 1
}
terrain_features = [{
"type": "sacred_ground",
"position": Vector2i(2, 4),
"radius": 0,
"effect": "The west eclipse tablet restores one rule for the final tower ascent."
}, {
"type": "narrow_pass",
"position": Vector2i(3, 4),
"radius": 1,
"effect": "Collapsed outer paths funnel the squad toward the first lift."
}, {
"type": "high_ground",
"position": Vector2i(5, 5),
"radius": 0,
"effect": "The east lift latch overlooks the opening ascent lane."
}]
optional_objectives = [{
"id": "ch10_01_west_eclipse_tablet",
"description": "서쪽 식경 서판을 읽어 최종 탑 상승 규칙 하나를 복원한다.",
"condition": "flag:ch10_01_west_eclipse_tablet",
"star_value": 1
}, {
"id": "ch10_01_east_lift_latch",
"description": "동쪽 승강기 걸쇠를 풀어 첫 탑 진입로를 연다.",
"condition": "flag:ch10_01_east_lift_latch",
"star_value": 1
}]
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
stage_objective_hint = "식경 서판을 읽고 승강기를 해제해 첫 탑 진입을 시작한다."
interaction_objective_texts = PackedStringArray("식경 서판을 읽고 승강기 걸쇠를 풀어 첫 상승 경로를 연다. (0/2)", "상승 제어 지점 하나를 확보했다. 남은 탑 걸쇠를 해제한다. (1/2)", "상승 제어 지점 두 곳을 모두 확보했다. 첫 탑 경로가 열렸다. (2/2)")
interaction_objective_state_ids = [&"tower_ascent_locked", &"tower_ascent_partial", &"tower_ascent_open"]
landmark_labels = PackedStringArray("식경 서판", "외곽 승강기", "첫 공명탑")
start_cutscene_id = &"ch10_01_intro"
clear_cutscene_id = &"ch10_01_outro"
next_destination_summary = "다음: 외곽 승강기를 타고 첫 공명탑으로 향한다."
post_battle_bark_rules = [{
"id": "ch10_01_eclipse_eve_report_ready",
"speaker": "Guide",
"text": "외곽 승강기가 열렸다. 이제 전투는 길을 막는 것이 아니라, 이름을 지키며 올라가는 일이 됐다.",
"section": "story",
"conditions": {"outcome": "victory", "post_battle_handoff": true}
}, {
"id": "ch10_01_eclipse_tablet_ack",
"speaker": "Serin",
"text": "서쪽 식경 서판을 읽었어. 탑이 지우려는 규칙보다 우리가 기억한 이름이 먼저야.",
"section": "bonds",
"conditions": {"outcome": "victory", "optional_completed": ["ch10_01_west_eclipse_tablet"]}
}, {
"id": "ch10_01_lift_latch_ack",
"speaker": "Guide",
"text": "동쪽 승강기 걸쇠가 풀렸다. 첫 공명탑으로 오르는 길이 흔들림 없이 고정됐다.",
"section": "story",
"conditions": {"outcome": "victory", "optional_completed": ["ch10_01_east_lift_latch"]}
}, {
"id": "ch10_01_full_ascent_read",
"speaker": "System",
"text": "식경 서판 복원과 승강기 해제 결과가 최종 탑 상승 경로 판정에 반영됐다.",
"section": "telemetry",
"conditions": {"outcome": "victory", "optional_completed": ["ch10_01_west_eclipse_tablet", "ch10_01_east_lift_latch"]}
}]
