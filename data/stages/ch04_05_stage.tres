stage_objective_hint = "침수 수도원 수로는 이동을 늦춘다. 정화 장치와 연구 기록을 먼저 잡아 보스 제단 압박을 줄인다."
interaction_objective_texts = PackedStringArray("연구 기록 두 개를 회수하고 바실을 쓰러뜨려 침수 성소를 드러낸다. (0/2)", "연구 기록 하나를 확보했다. 마지막 기록을 회수하고 바실을 마무리한다. (1/2)", "연구 기록 두 개를 모두 확보했다. 바실의 침수 성소가 완전히 드러났다. (2/2)")
interaction_objective_state_ids = [&"basil_logs_missing", &"basil_logs_partial", &"basil_logs_complete"]
start_cutscene_id = &"ch04_05_intro"
clear_cutscene_id = &"ch04_05_outro"
next_destination_summary = "연구 봉인과 이송 장부가 다음 목적지를 잿빛 기록보관소로 가리킨다."
