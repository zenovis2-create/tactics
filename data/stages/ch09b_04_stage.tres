[resource]
script = ExtResource("1_stage")
stage_id = &"CH09B_04"
stage_title = "Rewritten Battlefield"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 2), Vector2i(3, 3), Vector2i(4, 2)]
terrain_move_costs = {
Vector2i(2, 5): 2,
Vector2i(5, 2): 2
}
terrain_types = {
Vector2i(2, 5): &"revision",
Vector2i(5, 2): &"revision"
}
terrain_defense_bonuses = {
Vector2i(2, 5): 1,
Vector2i(5, 2): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b"), ExtResource("8_object_c")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
objective_text = "Break both revision cores and erase the red annotation pillar to stop the battlefield rewrite."
interaction_objective_texts = PackedStringArray("Break both revision cores and erase the red annotation pillar to stop the battlefield rewrite. (0/3)", "One revision anchor is broken. Tear down the remaining rewrite points. (1/3)", "Two revision anchors are broken. Erase the final rewrite point. (2/3)", "Revision chain broken. The battlefield stops rewriting itself. (3/3)")
interaction_objective_state_ids = [&"revision_chain_locked", &"revision_chain_partial", &"revision_chain_destabilized", &"revision_chain_broken"]
start_cutscene_id = &"ch09b_04_intro"
clear_cutscene_id = &"ch09b_04_outro"
next_destination_summary = "The revision cores break, exposing the last descent into the deep archive."
