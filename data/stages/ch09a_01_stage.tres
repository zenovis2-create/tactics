[resource]
script = ExtResource("1_stage")
stage_id = &"CH09A_01"
stage_title = "Outer Defense Line"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 3), Vector2i(4, 3), Vector2i(4, 4)]
terrain_move_costs = {
Vector2i(2, 4): 2,
Vector2i(5, 5): 2
}
terrain_types = {
Vector2i(2, 4): &"checkpoint",
Vector2i(5, 5): &"checkpoint"
}
terrain_defense_bonuses = {
Vector2i(2, 4): 1,
Vector2i(5, 5): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
stage_objective_hint = "외곽선 제어점 두 곳을 끊어 전방 경로를 카일의 교량 구역으로 수렴시킨다."
interaction_objective_texts = PackedStringArray("방어 서판을 회수하고 신호 군기를 끊어 외곽선을 무너뜨린다. (0/2)", "방어선 제어 지점 하나를 확보했다. 남은 경로 지점을 무너뜨린다. (1/2)", "방어선 제어 지점 두 곳을 모두 확보했다. 외곽선이 무너졌다. (2/2)")
interaction_objective_state_ids = [&"outer_line_locked", &"outer_line_partial", &"outer_line_broken"]
landmark_labels = PackedStringArray("방어 서판", "검문소 통로", "신호 군기")
start_cutscene_id = &"ch09a_01_intro"
clear_cutscene_id = &"ch09a_01_outro"
next_destination_summary = "다음: 무너진 외곽선을 넘어 카일의 교량 구역으로 진입한다."
