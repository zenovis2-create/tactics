loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Recover the defense tablet and cut the signal standard to break the outer line. (0/2)", "One defense-line control is secured. Break the remaining route point. (1/2)", "Both defense-line controls are secured. The outer line is broken. (2/2)")
