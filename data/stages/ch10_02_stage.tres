clear_cutscene_id = &"ch10_02_outro"
next_destination_summary = "다음: 무너진 외곽 고리를 지나 무명의 회랑으로 들어간다."
post_battle_bark_rules = [{
"id": "ch10_02_tower_crest_report_ready",
"speaker": "Guide",
"text": "외곽 탑 고리가 무너졌다. 흩어지면 끊기는 길이지만, 함께라면 안쪽 회랑으로 이어진다.",
"section": "story",
"conditions": {"outcome": "victory", "post_battle_handoff": true}
}, {
"id": "ch10_02_west_crest_ack",
"speaker": "Rian",
"text": "서쪽 문장 제어가 무너졌다. 이 탑은 우리를 떼어 놓으려 하지만, 기억은 혼자 들 수 없어.",
"section": "bonds",
"conditions": {"outcome": "victory", "optional_completed": ["ch10_02_west_crest_control"]}
}, {
"id": "ch10_02_east_crest_ack",
"speaker": "Guide",
"text": "동쪽 문장 제어를 부쉈다. 내부 회랑으로 향하는 안정 경로가 외곽 고리 안에서 드러났다.",
"section": "story",
"conditions": {"outcome": "victory", "optional_completed": ["ch10_02_east_crest_control"]}
}, {
"id": "ch10_02_full_crest_read",
"speaker": "System",
"text": "서쪽·동쪽 문장 제어 파괴 결과가 공명탑 외곽 고리 붕괴 판정에 반영됐다.",
"section": "telemetry",
"conditions": {"outcome": "victory", "optional_completed": ["ch10_02_west_crest_control", "ch10_02_east_crest_control"]}
}]
