"type": "destructible",
"position": Vector2i(2, 5),
"radius": 0,
"effect": "The west crest control can be broken to weaken the outer tower ring."
}, {
"type": "narrow_pass",
"position": Vector2i(4, 4),
"radius": 1,
"effect": "The resonance crest bends the outer ring into one unstable crossing."
}, {
"type": "high_ground",
"position": Vector2i(5, 2),
"radius": 0,
"effect": "The east crest control watches the inner corridor approach."
}]
optional_objectives = [{
"id": "ch10_02_west_crest_control",
"description": "서쪽 공명 문장 제어점을 부숴 외곽 탑 고리의 첫 결속을 끊는다.",
"condition": "flag:ch10_02_west_crest_control",
"star_value": 1
}, {
"id": "ch10_02_east_crest_control",
"description": "동쪽 공명 문장 제어점을 부숴 내부 회랑으로 가는 안정 경로를 만든다.",
"condition": "flag:ch10_02_east_crest_control",
"star_value": 1
}]
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
stage_objective_hint = "문장 제어점 두 곳을 무너뜨려 외곽 고리에서 내부 회랑으로 이어지는 안정 경로를 만든다."
interaction_objective_texts = PackedStringArray("공명 문장 제어점 두 곳을 부숴 외곽 탑 고리를 무너뜨린다. (0/2)", "문장 제어점 하나를 무너뜨렸다. 남은 외곽 탑 문장을 붕괴시킨다. (1/2)", "문장 제어점 두 곳이 모두 무너졌다. 외곽 탑 고리가 붕괴되었다. (2/2)")
interaction_objective_state_ids = [&"tower_crest_locked", &"tower_crest_partial", &"tower_crest_broken"]
landmark_labels = PackedStringArray("서쪽 문장 제어", "외곽 탑 고리", "동쪽 문장 제어")
weather_type = "night"
