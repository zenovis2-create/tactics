"type": "sacred_ground",
"position": Vector2i(1, 2),
"radius": 1,
"effect": "A broken sanctuary marker steadies surviving knights who regroup nearby."
}, {
"type": "sacred_ground",
"position": Vector2i(6, 4),
"radius": 1,
"effect": "The east relief marker gives a second recovery point near the enemy flank."
}, {
