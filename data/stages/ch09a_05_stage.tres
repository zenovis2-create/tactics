win_condition = &"resolve_all_interactions_and_defeat_all_enemies"
loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("Break all three censor seals, then defeat Varten's remaining censor line. (0/3)", "One censor seal is broken. Cut the remaining censor anchors. (1/3)", "Two censor seals are broken. Collapse the final censor route. (2/3)", "All censor seals are broken. Defeat Varten and the remaining censor line. (3/3)")
