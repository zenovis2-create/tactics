[gd_resource type="Resource" script_class="StageData" load_steps=9 format=3]

[ext_resource type="Script" path="res://scripts/data/stage_data.gd" id="1_stage"]
[ext_resource type="Resource" path="res://data/units/ally_vanguard.tres" id="2_ally_a"]
[ext_resource type="Resource" path="res://data/units/ally_scout.tres" id="3_ally_b"]
[ext_resource type="Resource" path="res://data/units/enemy_raider.tres" id="4_enemy_a"]
[ext_resource type="Resource" path="res://data/units/enemy_skirmisher.tres" id="5_enemy_b"]
[ext_resource type="Resource" path="res://data/objects/ch02_04_west_tunnel_control.tres" id="6_object_a"]
[ext_resource type="Resource" path="res://data/objects/ch02_04_south_tunnel_control.tres" id="7_object_b"]
[ext_resource type="Resource" path="res://data/objects/ch02_04_inner_gate_control.tres" id="8_object_c"]

[resource]
script = ExtResource("1_stage")
stage_id = &"CH02_04"
stage_title = "Under the Iron Gate"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 2), Vector2i(3, 3), Vector2i(4, 2)]
terrain_move_costs = {
Vector2i(2, 5): 2,
Vector2i(4, 4): 2,
Vector2i(5, 5): 2,
}
terrain_types = {
Vector2i(2, 5): &"tunnel",
Vector2i(4, 4): &"gate_control",
Vector2i(5, 5): &"tunnel",
}
terrain_defense_bonuses = {
Vector2i(2, 5): 1,
Vector2i(4, 4): 1,
Vector2i(5, 5): 1,
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b"), ExtResource("8_object_c")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("세 개의 터널 제어점을 확보해 하드렌 내부 성문을 드러낸다. (0/3)", "터널 제어점 하나를 맞췄다. 남은 제어점을 확보한다. (1/3)", "터널 제어점 둘을 확보했다. 마지막 제어점을 장악한다. (2/3)", "모든 터널 제어점이 맞춰졌다. 내부 성문 진입로가 드러났다. (3/3)")
interaction_objective_state_ids = [&"fortress_controls_unsecured", &"fortress_controls_one_secured", &"fortress_controls_two_secured", &"fortress_controls_exposed"]
start_cutscene_id = &"ch02_04_intro"
clear_cutscene_id = &"ch02_04_outro"
next_destination_summary = "터널 제어망이 맞물리며 하드렌의 군기 전당이 마침내 모습을 드러낸다."
