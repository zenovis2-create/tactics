[resource]
script = ExtResource("1_stage")
stage_id = &"CH03_03"
stage_title = "Refugee Column"
grid_size = Vector2i(8, 8)
cell_size = Vector2i(64, 64)
ally_units = [ExtResource("2_ally_a"), ExtResource("3_ally_b")]
enemy_units = [ExtResource("4_enemy_a"), ExtResource("5_enemy_b")]
ally_spawns = [Vector2i(1, 6), Vector2i(2, 6)]
enemy_spawns = [Vector2i(5, 1), Vector2i(6, 1)]
blocked_cells = [Vector2i(3, 2), Vector2i(3, 3), Vector2i(4, 3)]
terrain_move_costs = {
Vector2i(2, 5): 2,
Vector2i(5, 2): 2
}
terrain_types = {
Vector2i(2, 5): &"mud",
Vector2i(5, 2): &"mud"
}
terrain_defense_bonuses = {
Vector2i(2, 5): 1,
Vector2i(5, 2): 1
}
interactive_objects = [ExtResource("6_object_a"), ExtResource("7_object_b")]
win_condition = &"resolve_all_interactions"
loss_condition = &"all_allies_defeated"
interaction_objective_texts = PackedStringArray("경로 보관함을 열고 산불 흔적을 조사해 난민 대열을 인도한다. (0/2)", "난민 대열 단서 하나를 확보했다. 남은 단서를 찾는다. (1/2)", "난민 대열 단서 두 개를 모두 확보했다. 분지 경로가 확정되었다. (2/2)")
interaction_objective_state_ids = [&"refugee_column_unread", &"refugee_column_partial", &"refugee_column_confirmed"]
start_cutscene_id = &"ch03_03_intro"
clear_cutscene_id = &"ch03_03_outro"
next_destination_summary = "난민 경로와 산불 흔적이 맞물리며 그린우드 깊숙한 분지 길이 드러난다."
